# ===== Telabotpower environment =====
# Copy values into .env (Prisma + Next read it). Never commit real secrets.

# --- Database (Phase 4) — Neon / Vercel Postgres ---
# DATABASE_URL = pooled connection (app). DIRECT_URL = direct connection (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (Phase 4) ---
JWT_SECRET="generate-a-long-random-string"
ENCRYPTION_KEY="generate-a-long-random-string"   # encrypt bot token at rest

# --- Upstash Redis (Phase 4/7) — lockout, session, online status, rate-limit ---
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# --- Telegram Bot (Phase 5) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET="generate-a-long-random-string"

# --- AI (Phase 6) ---
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
VOYAGE_API_KEY=""
# AI_BASE_URL=""   # (option) OpenAI-compatible endpoint for Hermes/Typhoon
# AI_API_KEY=""

# --- File storage (Phase 6) — Vercel Blob ---
BLOB_READ_WRITE_TOKEN=""

# --- Data source toggle ---
# true  = pages use mock data (lib/mock)
# false = pages use real API/DB
NEXT_PUBLIC_USE_MOCK="true"
